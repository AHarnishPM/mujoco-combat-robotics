<mujoco model="nhrl_arena_8x8">
  <compiler angle="degree" coordinate="local"/>
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <visual>
    <headlight ambient="0.35 0.35 0.35" diffuse="0.7 0.7 0.7" specular="0.1 0.1 0.1"/>
    <map znear="0.01"/>
    <quality shadowsize="2048"/>
  </visual>

  <asset>
    <!-- Arena floor is 8ft x 8ft = 2.4384m x 2.4384m -->
    <texture name="floor_nhrl" type="2d" file="textures/nhrl_floor_texture.png"/>
    <material name="mat_floor" texture="floor_nhrl" texrepeat="1 1" reflectance="0.05" rgba="1 1 1 1"/>
    <material name="mat_wall" rgba="0.7 0.75 0.8 0.25" specular="0.2"/>
    <!-- Replace with your CAD exports (STL/OBJ) -->
    <mesh name="chassis_mesh" file="meshes/huey_base.stl" scale="0.001 0.001 0.001"/>
    <mesh name="top_left_wheel_mesh" file="meshes/top_left_wheel.stl" scale="0.001 0.001 0.001"/>
    <mesh name="bottom_left_wheel_mesh" file="meshes/bottom_left_wheel.stl" scale="0.001 0.001 0.001"/>
    <mesh name="top_right_wheel_mesh" file="meshes/top_right_wheel.stl" scale="0.001 0.001 0.001"/>
    <mesh name="bottom_right_wheel_mesh" file="meshes/bottom_right_wheel.stl" scale="0.001 0.001 0.001"/>
    <mesh name="weapon_mesh" file="meshes/weapon.stl" scale="0.0009 0.0009 0.0009"/>
  </asset>

  <default>
    <geom friction="1.0 0.02 0.001" condim="3"/>
    <joint damping="0.1" armature="0.001"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>

    <default class="wheel_joint">
      <joint damping="0.35" armature="0.004"/>
    </default>
    <default class="wheel_geom">
      <geom friction="2.2 0.01 0.0005" contype="1" conaffinity="1"/>
    </default>
  </default>

  <worldbody>
    <light name="arena_light_1" pos="0 0 3.0" dir="0 0 -1" directional="true" diffuse="1 1 1"/>
    <light name="arena_light_2" pos="1.5 -1.5 2.5" diffuse="0.6 0.6 0.6"/>

    <!-- Floor top surface at z = 0 -->
    <geom name="arena_floor"
          type="box"
          size="1.2192 1.2192 0.02"
          pos="0 0 0"
          material="mat_floor"
          contype="1"
          conaffinity="1"/>

    <!-- Approximate NHRL lexan/perimeter boundary walls -->
    <geom name="north_wall" type="box" size="1.2192 0.0127 0.2032" pos="0 1.2319 0.2032" material="mat_wall" contype="1" conaffinity="1"/>
    <geom name="south_wall" type="box" size="1.2192 0.0127 0.2032" pos="0 -1.2319 0.2032" material="mat_wall" contype="1" conaffinity="1"/>
    <geom name="east_wall"  type="box" size="0.0127 1.2192 0.2032" pos="1.2319 0 0.2032" material="mat_wall" contype="1" conaffinity="1"/>
    <geom name="west_wall"  type="box" size="0.0127 1.2192 0.2032" pos="-1.2319 0 0.2032" material="mat_wall" contype="1" conaffinity="1"/>

    <!-- Default robot so arena file is immediately drivable -->
    <body name="robot" pos="0 0 0.035">
      <freejoint/>

      <!-- Option A: quick primitive chassis for tuning-->
      <!-- 3 lb bot target mass split: chassis 0.90kg, weapon 0.34kg, wheels 0.03kg each -->
      <!-- <geom name="chassis_col" type="box" size="0.10 0.08 0.03" mass="0.8" rgba="0.25 0.25 0.3 1"/> -->
      <!-- Hidden low ballast to keep center of mass down and reduce tipping/floaty feel -->
      <!-- <geom name="chassis_ballast" type="box" pos="0 0 -0.02" size="0.07 0.055 0.008" mass="0.41" rgba="0 0 0 0"/> --> -->

      <!-- Option B: visual mesh + simpler collision proxy -->
      <geom type="mesh" mesh="chassis_mesh" rgba="0.25 0.25 0.3 1" contype="0" conaffinity="0"/>

      <!-- Left drive wheels -->
      <body name="wheel_front_left" pos="0.09 -0.06 0.03">
        <joint name="wheel_front_left_joint" class="wheel_joint" type="hinge" axis="1 0 0"/>
        <geom type="mesh" mesh="top_left_wheel_mesh" rgba="0.05 0.05 0.05 1"/>
      </body>

      <body name="wheel_rear_left" pos="0.09 0.06 0.03">
        <joint name="wheel_rear_left_joint" class="wheel_joint" type="hinge" axis="1 0 0"/>
        <geom type="mesh" mesh="bottom_left_wheel_mesh" rgba="0.05 0.05 0.05 1"/>
      </body>

      <!-- Right drive wheels -->
      <body name="wheel_front_right" pos="-0.09 -0.06 0.03">
        <joint name="wheel_front_right_joint" class="wheel_joint" type="hinge" axis="1 0 0"/>
        <geom type="mesh" mesh="top_right_wheel_mesh" rgba="0.05 0.05 0.05 1"/>
      </body>

      <body name="wheel_rear_right" pos="-0.09 0.06 0.03">
        <joint name="wheel_rear_right_joint" class="wheel_joint" type="hinge" axis="1 0 0"/>
        <geom type="mesh" mesh="bottom_right_wheel_mesh" rgba="0.05 0.05 0.05 1"/>
      </body>

      <!-- Front-bottom horizontal spinner (flat-ish square) -->
      <body name="weapon" pos="0 -0.06 0">
        <joint name="weapon_joint" type="hinge" pos = "0 0 0" axis="0 0 1"/>
        <geom type="mesh" mesh="weapon_mesh" rgba="0.75 0.1 0.1 1"/>
      </body>
    </body>

    <camera name="iso" pos="2.8 -2.8 2.0" xyaxes="0.707 0.707 0 -0.4 0.4 0.82"/>
    <camera name="top_down" pos="0 0 3.2" xyaxes="1 0 0 0 1 0"/>
  </worldbody>

  <statistic center="0 0 0" extent="2.0"/>

  <actuator>
    <motor name="left_front_drive_motor"  joint="wheel_front_left_joint"  gear="0.9" ctrllimited="true" ctrlrange="-45 45"/>
    <motor name="left_rear_drive_motor"   joint="wheel_rear_left_joint"   gear="0.9" ctrllimited="true" ctrlrange="-45 45"/>
    <motor name="right_front_drive_motor" joint="wheel_front_right_joint" gear="0.9" ctrllimited="true" ctrlrange="-45 45"/>
    <motor name="right_rear_drive_motor"  joint="wheel_rear_right_joint"  gear="0.9" ctrllimited="true" ctrlrange="-45 45"/>
    <motor name="weapon_motor"      joint="weapon_joint"      gear="0.16" ctrllimited="true" ctrlrange="0 130"/>
  </actuator>
</mujoco>
